{
  "name": "marthington-bms",
  "productName": "Marthington BMS",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.js",

  "scripts": {
    "client": "vite",

    "electron": "electron .",

    "dev": "concurrently \"npm run client\" \"wait-on http://localhost:5173 && npm run electron\"",

    "build": "vite build",

    "preview": "vite preview",

    "dist": "npm run build && electron-builder"
  },

  "build": {
    "appId": "com.marthington.bms",

    "productName": "Marthington BMS",

    "directories": {
      "output": "dist-electron"
    },

    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],

    "win": {
      "target": "nsis"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },

  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  }
}