{
  "name": "marthington-bms",
  "productName": "Marthington BMS",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.js",

  "scripts": {
    "client": "cd frontend && vite",

    "build-client": "cd frontend && vite build",

    "electron": "electron .",

    "dev": "concurrently \"npm run client\" \"wait-on http://localhost:5173 && npm run electron\"",

    "dist": "npm run build-client && electron-builder"
  },

  "build": {
    "appId": "com.marthington.bms",

    "productName": "Marthington BMS",

    "copyright": "Copyright © 2026 Marthington",

    "directories": {
      "output": "dist-electron"
    },

    "files": [
      "frontend/dist/**/*",
      "electron/**/*",
      "package.json"
    ],

    "extraMetadata": {
      "main": "electron/main.js"
    },

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],

      "artifactName": "Marthington-BMS-Setup.${ext}",

      "icon": "frontend/public/logo.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Marthington BMS"
    }
  },

  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}